APP_NAME=LanShout
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:82
APP_PORT=82

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=infrastructure-pgsql
DB_PORT=5432
DB_DATABASE=lanshout
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=infrastructure-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=infrastructure-mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_PORT=5175
# Default locale for the application (en, de). Users can override this in their profile settings.
VITE_DEFAULT_LOCALE=de

# LanCore SSO Integration
LANCORE_ENABLED=false
LANCORE_BASE_URL=http://localhost
LANCORE_INTERNAL_URL=http://lancore.test
LANCORE_TOKEN=
LANCORE_APP_SLUG=lanshout
LANCORE_CALLBACK_URL="${APP_URL}/auth/lancore/callback"
LANCORE_TIMEOUT=5
LANCORE_RETRIES=2
LANCORE_RETRY_DELAY=100
